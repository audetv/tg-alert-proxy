# Telegram MTProto Proxy Secret (обязательно для работы с прокси)
TG_WS_PROXY_SECRET=your_secret_here

# Прокси настройки
TG_WS_PROXY_ENABLED=true
TG_WS_PROXY_ADDR=tg-ws-proxy:1443

# Telegram API credentials (опционально, есть значения по умолчанию)
TG_APP_ID=2040
TG_APP_HASH=b18441a1ff607e10a989891a5462e627

# HTTP порт
HTTP_PORT=8080

# Очередь сообщений
QUEUE_MAX_SIZE=100

# Метрики Prometheus
METRICS_ENABLED=true